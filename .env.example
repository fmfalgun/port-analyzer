# NVD API key — free at https://nvd.nist.gov/developers/request-an-api-key
# Without key: 5 req/30s. With key: 50 req/30s.
NVD_API_KEY=

# GreyNoise Community API key — free at https://www.greynoise.io/
GREYNOISE_API_KEY=

# Database path (default: db/port_analyzer.db)
DB_PATH=db/port_analyzer.db

# Backend secret for admin operations — MUST be changed before deploying.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_SECRET=

# CORS allowed origins (comma-separated, for backend).
# REQUIRED — the server will refuse to start if this is left empty or set to '*'
# unless you also set CORS_ALLOW_WILDCARD=1 (not recommended for production).
CORS_ORIGINS=http://localhost:8000,https://YOUR_DOMAIN
